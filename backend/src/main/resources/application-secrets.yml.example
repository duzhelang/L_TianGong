# ============================================================
# 第三方 API 配置
# ============================================================
apihz:
  id: ${APIHZ_ID:your-apihz-id}
  key: ${APIHZ_KEY:your-apihz-key}

# ============================================================
# AI服务密钥配置
# 使用说明：复制此文件为 application-secrets.yml，填入真实密钥
# ============================================================

app:
  ai:
    enabled: true
    default-provider: openrouter
    timeout-seconds: 30
    providers:
      # OpenRouter 聚合平台（免费模型）
      openrouter:
        base-url: https://openrouter.ai/api/v1
        api-key: ${OPENROUTER_API_KEY:your-openrouter-api-key}
        default-model: qwen3-next
        models:
          deepseek-v4-flash: deepseek/deepseek-v4-flash:free
          kimi-k2.6: moonshotai/kimi-k2.6:free
          gemma-4: google/gemma-4-26b-a4b-it:free
          qwen3-next: qwen/qwen3-next-80b-a3b-instruct:free
          qwen3-coder: qwen/qwen3-coder:free
          llama-4-scout: meta-llama/llama-4-scout:free

      # 智谱AI
      zhipu:
        base-url: https://open.bigmodel.cn/api/paas/v4
        api-key: ${ZHIPU_API_KEY:your-zhipu-api-key}
        default-model: glm-4-flash
        models:
          glm-4-flash: glm-4-flash
          glm-4v-flash: glm-4v-flash

      # DeepSeek
      deepseek:
        base-url: https://api.deepseek.com
        api-key: ${DEEPSEEK_API_KEY:your-deepseek-api-key}
        default-model: deepseek-v3
        models:
          deepseek-v3: deepseek-v3
          deepseek-coder: deepseek-coder

      # Kimi (Moonshot)
      kimi:
        base-url: https://api.moonshot.cn/v1
        api-key: ${KIMI_API_KEY:your-kimi-api-key}
        default-model: moonshot-v1-8k
        models:
          moonshot-v1-8k: moonshot-v1-8k
          moonshot-v1-32k: moonshot-v1-32k
          moonshot-v1-128k: moonshot-v1-128k

      # 小米 MiMo
      mimo:
        base-url: https://api.xiaomimimo.com/v1
        api-key: ${MIMO_API_KEY:your-mimo-api-key}
        default-model: mimo-7b
        models:
          mimo-7b: mimo-7b

      # NVIDIA NIM
      nvidia:
        base-url: https://integrate.api.nvidia.com/v1
        api-key: ${NVIDIA_API_KEY:your-nvidia-api-key}
        default-model: deepseek-v4-flash
        models:
          glm-5: zai-org/glm-5
          deepseek-v4-flash: deepseek-ai/deepseek-v4-flash
          kimi-k2.6: moonshotai/kimi-k2.6
          qwen3.5: qwen/qwen3.5-397b-a17b
          llama-4-scout: meta/llama-4-scout

      # 千问（通过 OpenRouter 访问）
      qwen:
        base-url: https://openrouter.ai/api/v1
        api-key: ${QWEN_API_KEY:your-qwen-api-key}
        default-model: qwen3.6-plus
        models:
          qwen3.6-plus: qwen/qwen3.6-plus
          qwen-turbo: qwen/qwen-turbo
